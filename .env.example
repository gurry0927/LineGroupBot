# LINE Bot credentials
# Get from LINE Developers Console → Your Channel → Basic Settings
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Immich instance
# Your self-hosted Immich URL and API key
IMMICH_URL=https://your-immich.example.com
IMMICH_API_KEY=

# Database path (inside container, do not change unless you know what you are doing)
DB_PATH=data/bot.db
